# -----------------------------------------------------------------------
# Google Analytics 4
# -----------------------------------------------------------------------

# Your 9-digit GA4 Property ID (found in Admin > Property Settings)
GA_PROPERTY_ID=123456789

# Full JSON string from your Google Service Account key file.
# In Vercel paste the entire contents of the .json file as one line.
# Locally you can keep it multiline inside single quotes if using bash:
#   export GA_SERVICE_ACCOUNT_KEY='{ "type": "service_account", ... }'
GA_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# -----------------------------------------------------------------------
# Kontent.ai
# -----------------------------------------------------------------------

# Your Kontent.ai Environment ID (Project Settings > API keys)
VITE_ENVIRONMENT_ID=your-kontent-environment-id
